{
  "name": "billed",
  "version": "0.1.2",
  "description": "Generate professional PDF invoices from your terminal",
  "author": "Alex",
  "keywords": [
    "invoice",
    "cli",
    "billing",
    "pdf",
    "terminal",
    "invoicing"
  ],
  "homepage": "https://billed.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/willemhubert/billed"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "node esbuild.config.js --watch && node dist/bill.js",
    "build": "node esbuild.config.js",
    "start": "node dist/bill.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@xmldom/xmldom": "^0.9.10",
    "chalk": "^5.6.2",
    "handlebars": "^4.7.9",
    "luxon": "^3.7.2",
    "ora": "^9.3.0",
    "pdfkit": "^0.18.0",
    "picocolors": "^1.1.1",
    "svg-to-pdfkit": "^0.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chalk": "^0.4.31",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/pdfkit": "^0.17.6",
    "@types/svg-to-pdfkit": "^0.1.4",
    "@vitest/ui": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
